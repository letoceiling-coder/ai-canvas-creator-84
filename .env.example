# Скопируйте в `.env` и заполните. Файл `.env` не коммитится.

# Ollama (OpenAI-compatible chat) — на VPS задавайте OLLAMA_* : они читаются в runtime из process.env (PM2).
# VITE_* для этих ключей в проде часто не работают без пересборки: значения вшиваются при vite build.
OLLAMA_API_TOKEN=
# Полный URL или база до /v1 (будет дополнен /chat/completions), например:
# OLLAMA_CHAT_URL=https://ollama.siteaacess.store/v1
# OLLAMA_CHAT_URL=https://ollama.siteaacess.store/v1/chat/completions
OLLAMA_CHAT_URL=
# Опционально, только для локальной dev-сборки с тем же ключом:
# VITE_OLLAMA_API_TOKEN=
# VITE_OLLAMA_CHAT_URL=

# Tavily (web search / data / ui fallbacks)
TAVILY_API_KEY=

# Context7 — прямой API (приоритет): https://context7.com/docs/api-guide
CONTEXT7_API_KEY=

# Опционально: свой прокси с телом { query } → { chunks: [{ id, text, source? }] }
# Если задан и прямой API не дал результат — будет попытка прокси.
CONTEXT7_PROXY_URL=

# OpenAI — канал image (POST /v1/images/generations). Без ключа — детерминированный placehold.co.
OPENAI_API_KEY=
# OPENAI_IMAGE_MODEL=dall-e-3

# Каталог JSON-проектов API /api/projects (по умолчанию ./data/projects)
# PROJECT_STORE_DIR=

# Vercel — однокликовый деплой экспортированного React-проекта (только сервер, см. POST /api/deploy)
# На VPS: положите значение в `.env` в корне проекта — `ecosystem.config.cjs` передаст его в PM2.
VERCEL_TOKEN=
# Необязательно: team / org в Vercel (query teamId для REST)
# VERCEL_TEAM_ID=

# POST /api/deploy/self-host + GET …/status: локальный hook на 127.0.0.1 (spawn bash + deploy.sh)
# Обязательно: тот же секрет в hook и в приложении: Authorization: Bearer …
DEPLOY_HOOK_SECRET=change-me-to-a-long-random-string
# LOCAL_DEPLOY_HOOK_URL=http://127.0.0.1:3099/run
# LOCAL_DEPLOY_HOOK_PORT=3099
# SELF_HOST_DEPLOY_ROOT=/var/www/botme.siteaacess.store
